# 모든 텍스트 파일은 저장소에서 LF로 정규화 (Windows CRLF 경고 방지)
* text=auto eol=lf

# 명시적 텍스트 (혼동 방지)
*.py     text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.json   text eol=lf
*.toml   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.cfg    text eol=lf
*.ipynb  text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
.env.example   text eol=lf

# 바이너리 / 대용량 데이터 (diff·정규화 제외)
*.parquet binary
*.graphml binary
*.osm     binary
*.pbf     binary
*.pt      binary
*.pth     binary
*.pkl     binary
*.joblib  binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.pdf     binary
