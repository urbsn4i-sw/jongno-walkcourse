# 무료 API 키 — 실제 값은 .env 에 채우고 절대 커밋하지 말 것 (.gitignore 처리됨)
# 이 파일(.env.example)은 어떤 키가 필요한지 알려주는 템플릿이다.
# 사용: cp .env.example .env  후 값 입력

# 카카오 개발자 (로컬 POI) — 무료 등록
KAKAO_REST_API_KEY=

# 네이버 개발자 (블로그/검색 언급량) — 무료 등록
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 공공데이터포털 TourAPI — 무료 등록
TOURAPI_SERVICE_KEY=

# 서울 열린데이터광장 (생활인구) — 무료 등록
SEOUL_OPENDATA_KEY=
